<?xml version="1.0"?>
<!--
PyBullet-loadable URDF generated from the original ROS xacro.

Notes:
- No xacro tags or ROS $(find ...) includes.
- Mesh URLs use relative paths: `meshes/...`
- Keep `p.setAdditionalSearchPath(<...>/sim/inmoov)` (or load with an absolute path)
  so Bullet can resolve `meshes/...` properly.
-->
<robot name="inmoov">
  <material name="base_gray"><color rgba="0.75 0.75 0.75 1"/></material>
  <material name="frame_green"><color rgba="0.2 0.9 0.2 1"/></material>

  <link name="world"/>

  <joint name="fixed" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.055"/>
      <mass value="5.0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
    </inertial>
    <visual>
      <geometry><cylinder length="0.11" radius="0.26"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0.055"/>
      <material name="base_gray"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.11" radius="0.26"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0.055"/>
    </collision>
  </link>

  <joint name="base_to_pedestal_link" type="fixed">
    <parent link="base_link"/>
    <child link="pedestal_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>

  <link name="pedestal_link">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.47"/>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <geometry><cylinder length="0.94" radius="0.0254"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0.47"/>
      <material name="base_gray"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.94" radius="0.0254"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0.47"/>
    </collision>
  </link>

  <joint name="pedestal_to_mid_stomach_joint" type="fixed">
    <parent link="pedestal_link"/>
    <child link="mid_stomach_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.94"/>
  </joint>

  <link name="mid_stomach_link">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <geometry><mesh filename="meshes/mid_stomach.stl" scale="0.001 0.001 0.001"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="base_gray"/>
    </visual>
    <collision>
      <geometry><mesh filename="meshes/mid_stomach.stl" scale="0.001 0.001 0.001"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>

  <joint name="mid_stomach_to_torso_joint" type="fixed">
    <parent link="mid_stomach_link"/>
    <child link="torso_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>

  <link name="torso_link">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <geometry><mesh filename="meshes/torso.stl" scale="0.001 0.001 0.001"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="base_gray"/>
    </visual>
    <collision>
      <geometry><mesh filename="meshes/torso.stl" scale="0.001 0.001 0.001"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>

  <link name="head_tilt_link">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <geometry><mesh filename="meshes/virtual.stl" scale="0.001 0.001 0.001"/></geometry>
      <origin rpy="0 0 3.1415" xyz="0 0 0"/>
      <material name="frame_green"/>
    </visual>
    <collision>
      <geometry><mesh filename="meshes/virtual.stl" scale="0.001 0.001 0.001"/></geometry>
      <origin rpy="0 0 3.1415" xyz="0 0 0"/>
    </collision>
  </link>

  <joint name="head_roll_joint" type="revolute">
    <parent link="torso_link"/>
    <child link="head_tilt_link"/>
    <origin rpy="0 0 3.1415" xyz="-0.0315 -0.001 0.4551"/>
    <axis xyz="1 0 0"/>
    <limit effort="1000.0" lower="-1.57" upper="1.57" velocity="2.0"/>
  </joint>

  <link name="head_base_link">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <geometry><mesh filename="meshes/head_base.stl" scale="0.001 0.001 0.001"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="base_gray"/>
    </visual>
    <collision>
      <geometry><mesh filename="meshes/head_base.stl" scale="0.001 0.001 0.001"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>

  <joint name="head_tilt_joint" type="revolute">
    <parent link="head_tilt_link"/>
    <child link="head_base_link"/>
    <origin rpy="0 0 3.1415" xyz="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="1000.0" lower="-1.57" upper="1.57" velocity="2.0"/>
  </joint>

  <link name="skull_link">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <geometry><mesh filename="meshes/skull.stl" scale="0.001 0.001 0.001"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="base_gray"/>
    </visual>
    <collision>
      <geometry><mesh filename="meshes/skull.stl" scale="0.001 0.001 0.001"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>

  <joint name="head_base_to_skull_joint" type="fixed">
    <parent link="head_base_link"/>
    <child link="skull_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>

  <link name="face_link">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <geometry><mesh filename="meshes/face.stl" scale="0.001 0.001 0.001"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="base_gray"/>
    </visual>
    <collision>
      <geometry><mesh filename="meshes/face.stl" scale="0.001 0.001 0.001"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>

  <joint name="face_joint" type="fixed">
    <parent link="skull_link"/>
    <child link="face_link"/>
    <origin rpy="0 0 0" xyz="0.0637 0 0.079"/>
  </joint>

  <link name="r_shoulder_base_link">
    <visual>
      <geometry><mesh filename="meshes/r_shoulder_base.stl" scale="0.001 0.001 0.001"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="base_gray"/>
    </visual>
  </link>

  <joint name="r_shoulder_out_joint" type="revolute">
    <parent link="torso_link"/>
    <child link="r_shoulder_base_link"/>
    <origin rpy="0 0 0" xyz="0 -0.143 0.298"/>
    <axis xyz="1 0 0"/>
    <limit effort="1000.0" lower="-2.0" upper="2.0" velocity="2.0"/>
  </joint>

  <link name="r_forearm_link">
    <visual>
      <geometry><mesh filename="meshes/r_forearm.stl" scale="0.001 0.001 0.001"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="base_gray"/>
    </visual>
  </link>

  <joint name="r_shoulderbase_to_r_forearm_joint" type="fixed">
    <parent link="r_shoulder_base_link"/>
    <child link="r_forearm_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>

  <link name="r_hand_link">
    <visual>
      <geometry><mesh filename="meshes/r_hand.stl" scale="0.001 0.001 0.001"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="base_gray"/>
    </visual>
  </link>

  <joint name="r_wrist_roll_joint" type="revolute">
    <parent link="r_forearm_link"/>
    <child link="r_hand_link"/>
    <origin rpy="0 0 0" xyz="-0.0144 0.01 -0.2885"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-2.0" upper="2.0" velocity="4.0"/>
  </joint>

  <link name="l_shoulder_base_link">
    <visual>
      <geometry><mesh filename="meshes/l_shoulder_base.stl" scale="0.001 0.001 0.001"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="base_gray"/>
    </visual>
  </link>

  <!-- Left shoulder now has 3 sequential axes (yaw->pitch->roll) so we can animate X/Y/Z separately. -->
  <link name="l_shoulder_yaw_link"/>
  <joint name="l_shoulder_yaw_joint" type="revolute">
    <parent link="torso_link"/>
    <child link="l_shoulder_yaw_link"/>
    <origin rpy="0 0 0" xyz="0 0.143 0.298"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-2.0" upper="2.0" velocity="2.0"/>
  </joint>

  <link name="l_shoulder_pitch_link"/>
  <joint name="l_shoulder_pitch_joint" type="revolute">
    <parent link="l_shoulder_yaw_link"/>
    <child link="l_shoulder_pitch_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="1000.0" lower="-2.0" upper="2.0" velocity="2.0"/>
  </joint>

  <joint name="l_shoulder_out_joint" type="revolute">
    <parent link="l_shoulder_pitch_link"/>
    <child link="l_shoulder_base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="1000.0" lower="-2.0" upper="2.0" velocity="2.0"/>
  </joint>

  <link name="l_forearm_link">
    <visual>
      <geometry><mesh filename="meshes/l_forearm.stl" scale="0.001 0.001 0.001"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="base_gray"/>
    </visual>
  </link>

  <joint name="l_shoulderbase_to_l_forearm_joint" type="fixed">
    <parent link="l_shoulder_base_link"/>
    <child link="l_forearm_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>

  <link name="l_hand_link">
    <visual>
      <geometry><mesh filename="meshes/l_hand.stl" scale="0.001 0.001 0.001"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="base_gray"/>
    </visual>
  </link>

  <joint name="l_wrist_roll_joint" type="revolute">
    <parent link="l_forearm_link"/>
    <child link="l_hand_link"/>
    <origin rpy="0 0 0" xyz="-0.0144 -0.01 -0.2885"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-2.0" upper="2.0" velocity="4.0"/>
  </joint>
</robot>